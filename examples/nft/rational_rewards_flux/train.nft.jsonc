{
  "$schema": "../../../schema/nft.schema.json",

  // Port of Flow-Factory examples/nft/lora/flux1/rational_rewards_t2i.yaml.
  // Requires a vLLM judge serving RationalRewards-8B-T2I (see api_base_url in
  // the reward block). Adjust dataset paths to your local cache.

  "checkpoint_root": "$auto",
  "auto_resume": true,
  "seed_checkpoint_dir": "/dev/shm/flow-control/seed",
  "experiment_name": "flux_nft_rational_rewards_512",

  "gradient_checkpointing": false,
  "rollout_storage_device": "device",
  "precompute_aux_model_outputs": true,

  // 48 unique prompts x 16 rollouts = 768 rollouts/epoch (FF: unique_sample_num
  // _per_epoch=48, group_size=16).
  "num_batches_per_epoch": 1,
  "num_prompts_per_batch": 48,
  "num_rollouts_per_prompt": 16,
  "num_inner_epochs": 1,

  // 768 rollouts x 5 train timesteps = 3840 train items. train_batch_size=1920
  // -> 2 optimizer steps/epoch (FF gradient_step_per_epoch=2: step 1 on-policy,
  // step 2 off-policy on the EMA-generated rollouts).
  "train_batch_size": 1920,

  "num_train_timesteps": 5,
  "timestep_range": 0.8, // noisiest 80% of the trajectory (FF timestep_range)
  "train_timestep_sampling": "stratified", // FF discrete stratified sampling
  "beta": 1.0,
  "clip_grad_norm": 1.0,
  "adv_clip_max": 5.0, // FF adv_clip_range
  "kl_beta": 0.002, // FF kl_beta (v-based KL via LoRA disable_adapter)

  "train_epochs": 500,
  "checkpoint_interval": 5,
  "validation_epochs": 10,
  "max_checkpoints": 10,

  "model": {
    "arch": "flux1",
    "type": "base",
    "peft_lora_rank": 64,
    "peft_lora_config": {
      "lora_alpha": 128,
      "init_lora_weights": "gaussian",
      "target_modules": [
        "attn.to_k",
        "attn.to_q",
        "attn.to_v",
        "attn.to_out.0",
        "attn.add_k_proj",
        "attn.add_q_proj",
        "attn.add_v_proj",
        "attn.to_add_out",
        "ff.net.0.proj",
        "ff.net.2",
        "ff_context.net.0.proj",
        "ff_context.net.2",
      ],
    },
  },

  "dataset": {
    "type": "pickle_directory",
    "path": "./data/pickscore_flux_512/train",
  },

  "rollout_sampler": {
    "steps": 20, // FF num_inference_steps
    "cfg_scale": 1.0, // FF guidance_scale
    "shift": { "type": "constant", "shift_value": 3.0 }, // FF time_shift
  },

  // Old-teacher / behaviour-policy EMA. decay=0.5 + linear ramp == FF
  // ema_decay=0.5, ema_decay_schedule=piecewise_linear, ramp_rate=0.001. This
  // is what makes sampling + the old prediction off-policy (FF off_policy=true).
  "ema_old": {
    "decay": 0.5,
    "warmup": {
      "flat_steps": 0,
      "ramp_rate": 0.001,
      "type": "linear_ramp",
    },
    "interval": 1,
  },

  "reward": {
    "type": "rational_rewards_t2i",
    "llm": {
      "base_url": "http://127.0.0.1:8000/v1",
      "api_key": "EMPTY",
      "model": "RationalRewards-8B-T2I",
      "temperature": 0.1,
      "max_tokens": 2048,
      "timeout": 300,
      "max_concurrency": 8,
    },
    "max_retries": 5,
    "aspects": ["text_faithfulness", "physical_quality", "text_rendering"],
  },

  // Single reward component, so FF's gdpo degenerates to per-group normalize
  // (its batch-norm is a no-op for one component). per_prompt with per-group
  // std is numerically equivalent here and matches FF global_std=false.
  "advantage": {
    "type": "per_prompt",
    "use_global_std": false,
  },

  "optimizer_config": {
    "class_name": "AdamW",
    "lr": 2e-4,
    "weight_decay": 1e-4,
  },

  "scheduler_config": {
    "class_name": "ConstantLR",
    "factor": 1,
  },

  "validation_dataset": {
    "type": "pickle_directory",
    "path": "./data/pickscore_flux_512/validation",
    "limit": 256,
  },

  "validation_sampler": {
    "steps": 28, // FF eval num_inference_steps
    "cfg_scale": 1.0,
    "shift": { "type": "constant", "shift_value": 3.0 },
  },

  "validation_log_images": 64,

  "processor": {
    "task": "t2i",
    "preset": "flux1",
    "default_resolution": [512, 512],
  },

  "launch": {
    "type": "nft",
    "devices": 4,
    "generate_dcp_seed": true,
    // Re-enable preprocess_config if the 512x512 latent/text cache is missing.
    // "preprocess_config": [
    //   "examples/nft/rational_rewards_flux/preprocess.512.jsonc",
    //   "examples/nft/rational_rewards_flux/validation.preprocess.512.jsonc",
    // ],
  },
}
