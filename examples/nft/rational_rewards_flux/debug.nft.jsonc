{
  "$schema": "../../../schema/nft.schema.json",

  // Tiny smoke test for the RationalRewards NFT pipeline. Requires a vLLM judge
  // serving RationalRewards-8B-T2I and the ./data/pickscore_flux_512 cache.

  "checkpoint_root": "$auto",
  "auto_resume": true,
  "seed_checkpoint_dir": "/dev/shm/flow-control/seed",
  "experiment_name": "flux_nft_rational_debug",

  "num_batches_per_epoch": 2,
  "num_prompts_per_batch": 2,
  "num_rollouts_per_prompt": 4,
  "num_inner_epochs": 1,
  "train_batch_size": 8,

  "num_train_timesteps": 2,
  "timestep_range": 0.8,
  "train_timestep_sampling": "stratified",
  "beta": 1.0,
  "clip_grad_norm": 1.0,
  "adv_clip_max": 5.0,
  // Non-zero so the debug exercises the v-based KL reference path
  // (transformer.disable_adapters()) that the full train config uses.
  "kl_beta": 0.002,

  "train_epochs": 20,
  "checkpoint_interval": 5,
  "validation_epochs": 5,

  "model": {
    "arch": "flux1",
    "type": "base",
    "peft_lora_rank": 64,
    "peft_lora_config": {
      "lora_alpha": 128,
      "init_lora_weights": "gaussian",
      "target_modules": [
        "attn.to_k",
        "attn.to_q",
        "attn.to_v",
        "attn.to_out.0",
        "attn.add_k_proj",
        "attn.add_q_proj",
        "attn.add_v_proj",
        "attn.to_add_out",
        "ff.net.0.proj",
        "ff.net.2",
        "ff_context.net.0.proj",
        "ff_context.net.2",
      ],
    },
  },

  "dataset": {
    "type": "pickle_directory",
    "path": "./data/pickscore_flux_512/train",
  },

  "rollout_sampler": {
    "steps": 8,
    "cfg_scale": 1.0,
    "shift": { "type": "constant", "shift_value": 3.0 },
  },

  "ema_old": {
    "decay": 0.5,
    "warmup": {
      "flat_steps": 0,
      "ramp_rate": 0.001,
      "type": "linear_ramp",
    },
    "interval": 1,
  },

  "reward": {
    "type": "rational_rewards_t2i",
    "llm": {
      "base_url": "http://127.0.0.1:8000/v1",
      "api_key": "EMPTY",
      "model": "RationalRewards-8B-T2I",
      "temperature": 0.1,
      "max_tokens": 2048,
      "timeout": 300,
      "max_concurrency": 4,
    },
    "max_retries": 5,
    "aspects": ["text_faithfulness", "physical_quality", "text_rendering"],
  },

  "advantage": {
    "type": "per_prompt",
    "use_global_std": false,
  },

  "optimizer_config": {
    "class_name": "AdamW",
    "lr": 2e-4,
    "weight_decay": 1e-4,
  },

  "scheduler_config": {
    "class_name": "ConstantLR",
    "factor": 1,
  },

  "validation_dataset": {
    "type": "pickle_directory",
    "path": "./data/pickscore_flux_512/validation",
    "limit": 8,
  },

  "validation_sampler": {
    "steps": 28,
    "cfg_scale": 1.0,
    "shift": { "type": "constant", "shift_value": 3.0 },
  },

  "processor": {
    "task": "t2i",
    "preset": "flux1",
    "default_resolution": [512, 512],
  },

  "launch": {
    "type": "nft",
    "devices": 4,
    "generate_dcp_seed": true,
  },
}
