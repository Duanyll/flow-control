{
  "$schema": "../../../schema/sft.schema.json",

  // Derived from train.sft.jsonc for end-to-end preemption/resume testing:
  // - aim_repo points to a local directory (the remote aim server is gone).
  // - smaller train_steps + tighter checkpoint_steps so we can trigger SIGUSR1
  //   early and still have runway for the second run to resume and finish.
  // - mid-training validation is effectively disabled (validation_steps > train_steps).

  "checkpoint_root": "./runs/sft/flux_preempt_test",
  "seed_checkpoint_dir": "/dev/shm/flow-control/seed",
  "aim_repo": "./runs/sft/aim_preempt_test",
  "experiment_name": "flux_sft_preempt_test",
  "max_checkpoints": 10,
  "validation_steps": 10000,
  "checkpoint_steps": 10,

  "gradient_checkpointing": true,
  "global_batch_size": 16,
  "train_steps": 100,

  "ema": {
    "decay": 1.0
  },

  "hsdp_shard_dim": 1,

  "model": {
    "arch": "flux1",
    "type": "base",
    "peft_lora_rank": 16
  },

  "validation_sampler": {
    "steps": 20,
    "cfg_scale": 1.0,
    "shift": { "type": "linear" }
  },

  "processor": {
    "task": "t2i",
    "preset": "flux1"
  },

  "optimizer_config": {
    "class_name": "AdamW",
    "lr": 5e-4
  },

  "scheduler_config": {
    "class_name": "ConstantLR",
    "factor": 1.0
  },

  "dataset": {
    "type": "pickle_directory",
    "path": "./data/christian_boragine/flux1"
  },

  "validation_dataset": {
    "type": "pickle_directory",
    "path": "./data/christian_boragine/flux1_validation"
  },

  "launch": {
    "type": "sft",
    "devices": "all",
    "generate_dcp_seed": true
  }
}
