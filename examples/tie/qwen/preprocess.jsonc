{
  "$schema": "../../../schema/preprocess.schema.json",
  "num_loader_workers": 1,
  "processor_devices": [
    0
  ],
  "num_threads_per_worker": 8,
  "queue_size": 16,
  "num_sink_workers": 1,
  "processing_mode": "inference",
  "dataset": {
    "type": "csv",
    "path": "./examples/tie.csv",
    "attachment_dir": "./examples/assets"
  },
  "processor": {
    "task": "tie",
    "preset": "qwen_image_edit"
  },
  "output": {
    "type": "pickle_directory",
    "path": "./demo/preprocess_qwen_tie"
  }
}
