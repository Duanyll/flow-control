{
  "$schema": "../../../schema/preprocess.schema.json",
  "num_loader_workers": 1,
  "processor_devices": [0],
  "num_threads_per_worker": 8,
  "queue_size": 16,
  "num_sink_workers": 1,
  "processing_mode": "inference",
  "save_extra": true,
  "dataset": {
    "type": "lines",
    "path": "./data/ocr/test.txt",
    "limit": 256,
  },
  "processor": {
    "task": "t2i",
    "preset": "sd35_medium",
    "default_resolution": [512, 512],
  },
  "output": {
    "type": "pickle_directory",
    "path": "./data/ocr_sd35/validation",
  },
}
